@model List<MyPortfolio.DAL.Entities.Skill>

@{
    ViewData["Title"] = "Skill List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card mt-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">My Skills</h4>
        <a href="/Skill/Create" class="btn btn-sm btn-success">Add New Skill</a>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Skill Title</th>
                    <th>Value (%)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.SkillId</td>
                        <td>@item.Title</td>
                        <td>
                            <div class="progress">
                                <div class="progress-bar bg-info" role="progressbar" style="width: @item.Value%" aria-valuenow="@item.Value" aria-valuemin="0" aria-valuemax="100">@item.Value%</div>
                            </div>
                        </td>
                        <td>
                            <a href="/Skill/Edit/@item.SkillId" class="btn btn-sm btn-primary">Edit</a>
                            <a href="/Skill/Delete/@item.SkillId" class="btn btn-sm btn-danger" onclick="return confirm('Delete this skill?');">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
