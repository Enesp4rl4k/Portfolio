@model List<MyPortfolio.DAL.Entities.Feature>

@{
    ViewData["Title"] = "Feature List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card mt-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Hero Features</h4>
        <a href="/Feature/Create" class="btn btn-sm btn-success">Add New</a>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.FeatureId</td>
                        <td>@item.Description</td>
                        <td>
                            <a href="/Feature/Edit/@item.FeatureId" class="btn btn-sm btn-primary">Edit</a>
                            <a href="/Feature/Delete/@item.FeatureId" class="btn btn-sm btn-danger" onclick="return confirm('Are you sure you want to delete this feature?');">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
