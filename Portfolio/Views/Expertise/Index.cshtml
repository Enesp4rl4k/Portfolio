@model List<MyPortfolio.DAL.Entities.Expertise>

@{
    ViewData["Title"] = "Expertise List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card mt-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Technical Expertise Cards</h4>
        <a href="/Expertise/Create" class="btn btn-sm btn-success">Add New Card</a>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>Icon</th>
                    <th>Description</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ExpertiseId</td>
                        <td>@item.Title</td>
                        <td><i class="@item.Icon"></i> (@item.Icon)</td>
                        <td>@item.Description</td>
                        <td>
                            <a href="/Expertise/Edit/@item.ExpertiseId" class="btn btn-sm btn-primary">Edit</a>
                            <a href="/Expertise/Delete/@item.ExpertiseId" class="btn btn-sm btn-danger" onclick="return confirm('Delete this card?');">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
