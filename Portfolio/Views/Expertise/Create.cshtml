@model MyPortfolio.DAL.Entities.Expertise

@{
    ViewData["Title"] = "Create Expertise";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card mt-4">
    <div class="card-header bg-success text-white">
        <h4 class="mb-0">Add New Expertise Card</h4>
    </div>
    <div class="card-body">
        <form method="post">
            <div class="mb-3">
                <label class="form-label">Title</label>
                <input type="text" class="form-control" name="Title" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Icon (Font Awesome Class, e.g., fas fa-rocket)</label>
                <input type="text" class="form-control" name="Icon" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea class="form-control" name="Description" rows="3" required></textarea>
            </div>
            <button class="btn btn-success" type="submit">Create Card</button>
            <a href="/Expertise/Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
