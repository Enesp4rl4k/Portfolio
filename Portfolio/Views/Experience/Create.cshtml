@model MyPortfolio.DAL.Entities.Experience

@{
    ViewData["Title"] = "Add Experience";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card mt-4">
    <div class="card-header bg-success text-white">
        <h4 class="mb-0">Add New Experience</h4>
    </div>
    <div class="card-body">
        <form method="post">
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Role (Head)</label>
                    <input type="text" class="form-control" name="Head" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Company (Title)</label>
                    <input type="text" class="form-control" name="Title" required />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Date (e.g. 2021 - Present)</label>
                <input type="text" class="form-control" name="Date" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Description</label>
                <textarea class="form-control" name="Description" rows="5" required></textarea>
            </div>
            <button class="btn btn-success" type="submit">Save Experience</button>
            <a href="/Experience/Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
