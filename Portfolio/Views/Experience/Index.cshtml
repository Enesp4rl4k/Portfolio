@model List<MyPortfolio.DAL.Entities.Experience>

@{
    ViewData["Title"] = "Experience List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card mt-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Experience Timeline</h4>
        <a href="/Experience/Create" class="btn btn-sm btn-success">Add New Experience</a>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Date</th>
                    <th>Role (Head)</th>
                    <th>Company (Title)</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.ExperienceId</td>
                        <td>@item.Date</td>
                        <td>@item.Head</td>
                        <td>@item.Title</td>
                        <td>
                            <a href="/Experience/Edit/@item.ExperienceId" class="btn btn-sm btn-primary">Edit</a>
                            <a href="/Experience/Delete/@item.ExperienceId" class="btn btn-sm btn-danger" onclick="return confirm('Delete this experience?');">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
