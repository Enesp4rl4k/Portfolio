@model MyPortfolio.DAL.Entities.Message

@{
    ViewData["Title"] = "Read Message";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card mt-4 border-primary">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Message from @Model.Namesurname</h4>
        <span class="badge bg-light text-dark">@Model.SenDate.ToString("dd MMM yyyy HH:mm")</span>
    </div>
    <div class="card-body">
        <div class="mb-4 pb-3 border-bottom">
            <h5 class="fw-bold">Subject: @Model.Subject</h5>
            <div class="text-muted mb-2">
                <i class="fas fa-envelope me-2"></i> <a href="mailto:@Model.Email">@Model.Email</a>
            </div>
        </div>
        
        <div class="message-content p-3 bg-light rounded" style="min-height: 150px; white-space: pre-wrap;">
            @Model.MessageDetail
        </div>
        
        <div class="mt-4 pt-3 text-end border-top">
            <a href="mailto:@Model.Email?subject=Re: @Model.Subject" class="btn btn-primary"><i class="fas fa-reply me-2"></i>Reply via Email</a>
            <a href="/Message/Delete/@Model.MessageId" class="btn btn-danger" onclick="return confirm('Delete this message perfectly?');"><i class="fas fa-trash me-2"></i>Delete</a>
            <a href="/Message/Index" class="btn btn-secondary ms-2">Back to Inbox</a>
        </div>
    </div>
</div>
