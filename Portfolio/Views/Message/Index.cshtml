@model List<MyPortfolio.DAL.Entities.Message>

@{
    ViewData["Title"] = "Inbox";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card mt-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Inbox Contacts</h4>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>Status</th>
                    <th>Sender</th>
                    <th>Email</th>
                    <th>Subject</th>
                    <th>Date</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr class="@(item.IsRead ? "" : "table-secondary fw-bold")">
                        <td class="text-center">
                            @if (item.IsRead)
                            {
                                <i class="fas fa-envelope-open text-muted" title="Read"></i>
                            }
                            else
                            {
                                <i class="fas fa-envelope text-primary" title="Unread"></i>
                            }
                        </td>
                        <td>@item.Namesurname</td>
                        <td><a href="mailto:@item.Email">@item.Email</a></td>
                        <td>@item.Subject</td>
                        <td>@item.SenDate.ToString("dd MMM yyyy HH:mm")</td>
                        <td>
                            <a href="/Message/Read/@item.MessageId" class="btn btn-sm btn-info text-white">Read</a>
                            <a href="/Message/Delete/@item.MessageId" class="btn btn-sm btn-danger" onclick="return confirm('Delete this message permanently?');">Delete</a>
                        </td>
                    </tr>
                }
                
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center py-4 text-muted">No messages found in your inbox.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
