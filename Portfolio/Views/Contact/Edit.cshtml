@model MyPortfolio.DAL.Entities.Contact

@{
    ViewData["Title"] = "Edit Contact Info";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card mt-4">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Edit Contact Information</h4>
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" name="ContactId" value="@Model.ContactId" />
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Main Title</label>
                    <input type="text" class="form-control" name="Title" value="@Model.Title" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Email Address</label>
                    <input type="email" class="form-control" name="Email" value="@Model.Email" required />
                </div>
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="form-label">Primary Phone (Phone1)</label>
                    <input type="text" class="form-control" name="Phone1" value="@Model.Phone1" required />
                </div>
                <div class="col-md-6 mb-3">
                    <label class="form-label">Secondary Phone (Phone2 - Optional)</label>
                    <input type="text" class="form-control" name="Phone2" value="@Model.Phone2" />
                </div>
            </div>
            <div class="mb-3">
                <label class="form-label">Physical Location</label>
                <input type="text" class="form-control" name="Address" value="@Model.Address" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Brief Description</label>
                <textarea class="form-control" name="Description" rows="3" required>@Model.Description</textarea>
            </div>
            <button class="btn btn-primary" type="submit">Update Contact Info</button>
            <a href="/Contact/Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
