<!DOCTYPE html>
<html lang="en">
    @await Component.InvokeAsync("_HeadComponentPartial")
<body>
    <canvas id="matrix-canvas"></canvas>




    <header class="hero-section">
        <div class="container">
            <p class="hero-pretitle">MIS STUDENT & BACKEND  DEVELOPER</p>
            <h1 class="hero-main-title">Backend <span id="typewriter"></span></h1>
            <p class="hero-desc">Architecting robust systems with .NET 8, Onion Architecture, and Enterprise Design Patterns.</p>

            <div class="hero-btns">
                <a href="#projects" class="btn-neon">View Projects</a>
                <a href="cv.pdf" target="_blank" class="btn-outline"><i class="fas fa-file-pdf"></i> View CV</a>
            </div>

            <div class="github-stats glass-card">
                <div class="stat-item">
                    <i class="fas fa-code-branch"></i>
                    <span id="repo-count">0</span>
                    <p>Repositories</p>
                </div>
                <div class="stat-item">
                    <i class="fas fa-project-diagram"></i>
                    <span id="projects-count">15+</span>
                    <p>Projects Completed</p>
                </div>
                <div class="stat-item">
                    <i class="fas fa-chart-line" style="color: #2ea44f;"></i>
                    <span id="contrib-count">0</span>
                    <p>Contributions (Year)</p>
                </div>
            </div>
        </div>
    </header>

    <main class="container">

        <section id="about">
            <h2 class="section-title">About <span>Me</span></h2>
            <div class="glass-card glow-on-hover" style="max-width: 800px; margin: 0 auto; text-align: center;">
                <span class="badge">MIS Student at EMU</span>
                <p style="margin-top: 15px; color: var(--text-gray);">
                    I am an MIS student specializing in <strong>C# and .NET 8</strong>. I build scalable, maintainable systems using <strong>Onion Architecture</strong>. My focus is on writing clean code that solves complex business problems efficiently.
                </p>
            </div>
        </section>

        <section id="expertise">
            <h2 class="section-title">Technical <span>Expertise</span></h2>



            <div class="work-grid">
                <div class="glass-card glow-on-hover h-100">
                    <i class="fas fa-layer-group"></i>
                    <h3>Enterprise Design</h3>
                    <p style="color: var(--text-gray);">Layered architectures for robust separation of concerns.</p>
                </div>
                <div class="glass-card glow-on-hover h-100">
                    <i class="fas fa-dot-circle"></i>
                    <h3>Onion Architecture</h3>
                    <p style="color: var(--text-gray);">Domain-Driven Design (DDD) focus with a decoupled core.</p>
                </div>
                <div class="glass-card glow-on-hover h-100">
                    <i class="fas fa-rocket"></i>
                    <h3>ASP.NET Core 8</h3>
                    <p style="color: var(--text-gray);">High-performance REST APIs with the latest .NET features.</p>
                </div>
            </div>

            <div class="tech-stack-wrapper">
                <p style="color: var(--text-gray); margin-bottom: 20px;">Technologies & Tools</p>
                <div class="tech-icons">
                    <i class="fab fa-docker" title="Docker"></i>
                    <i class="fas fa-database" title="SQL Server"></i>
                    <i class="fas fa-project-diagram" title="RabbitMQ"></i>
                    <i class="fas fa-network-wired" title="REST API"></i>
                    <i class="fab fa-git-alt" title="Git"></i>
                </div>
            </div>
        </section>

        <section id="projects">
            <h2 class="section-title">Featured <span>Projects</span></h2>
            <div class="projects-grid">
                <div class="project-card glow-on-hover">
                    <div class="project-img-wrapper"><img src="https://i.hizliresim.com/836oxnm.png" alt="BookCar"></div>
                    <div class="project-info">
                        <span class="badge">Onion Architecture</span>
                        <h3>BookCar API</h3>
                        <p style="color: var(--text-gray); font-size: 0.9rem;">Enterprise car rental system built with MediatR and CQRS patterns.</p>
                        <div class="project-links">
                            <a href="https://github.com/Enesp4rl4k/CarBook" target="_blank" class="btn-view-code"><i class="fab fa-github"></i> View Code</a>
                        </div>
                    </div>
                </div>

                <div class="project-card glow-on-hover">
                    <div class="project-img-wrapper"><img src="https://i.hizliresim.com/k6w7m2n.png" alt="AI Masterclass"></div>
                    <div class="project-info">
                        <span class="badge">AI Integration</span>
                        <h3>AI Masterclass</h3>
                        <p style="color: var(--text-gray); font-size: 0.9rem;">Integrating LLMs and 20+ AI models into specialized backend services.</p>
                        <div class="project-links">
                            <a href="https://github.com/Enesp4rl4k" target="_blank" class="btn-view-code"><i class="fab fa-github"></i> View Code</a>
                        </div>
                    </div>
                </div>

                <div class="project-card glow-on-hover">
                    <div class="project-img-wrapper"><img src="https://i.hizliresim.com/9l8x2z3.png" alt="Big Data"></div>
                    <div class="project-info">
                        <span class="badge">Data Analytics</span>
                        <h3>Big Data Visualizer</h3>
                        <p style="color: var(--text-gray); font-size: 0.9rem;">Visualization and predictive modeling for complex datasets.</p>
                        <div class="project-links">
                            <a href="https://github.com/Enesp4rl4k" target="_blank" class="btn-view-code"><i class="fab fa-github"></i> View Code</a>
                        </div>
                    </div>
                </div>

                <div class="project-card glow-on-hover" style="border: 2px dashed rgba(255, 255, 255, 0.15); background: rgba(255, 255, 255, 0.02); display: flex; align-items: center; justify-content: center; min-height: 380px;">
                    <div class="text-center">
                        <i class="fas fa-hammer fa-3x" style="color: var(--accent-purple); opacity: 0.6; margin-bottom: 20px;"></i>
                        <h3 style="color: rgba(255,255,255,0.7);">Coming Soon</h3>
                        <p style="color: var(--text-gray); font-size: 0.9rem;">A new architectural project is currently in the works.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="contact">
            <div class="contact-container">
                <div class="contact-card-space">
                    <h2 style="font-size: 3rem;">Let's <span>Get In Touch.</span></h2>
                    <p style="margin-top: 20px; color: var(--text-gray);">Currently open to internship and junior backend roles.</p>
                    <div style="display: flex; flex-direction: column; gap: 15px; margin-top: 30px;">

                        <div style="display: flex; align-items: center; gap: 15px;">
                            <i class="fas fa-envelope" style="color: var(--accent-blue); width: 25px;"></i>
                            <a href="mailto:eparlak996@gmail.com" class="contact-link">eparlak996@gmail.com</a>
                        </div>

                        <div style="display: flex; align-items: center; gap: 15px;">
                            <i class="fab fa-github" style="color: var(--accent-purple); width: 25px;"></i>
                            <a href="https://github.com/Enesp4rl4k" target="_blank" class="contact-link">github.com/Enesp4rl4k</a>
                        </div>

                        <div style="display: flex; align-items: center; gap: 15px;">
                            <i class="fab fa-linkedin" style="color: #0077b5; width: 25px;"></i>
                            <a href="https://www.linkedin.com/in/enes-parlak-032a33232/" target="_blank" class="contact-link">linkedin.com/in/enes-parlak</a>
                        </div>

                    </div>
                </div>
                <div class="sphere glow-on-hover"></div>
            </div>
        </section>
    </main>

    <script src="https://unpkg.com/scrollreveal"></script>
    <script>
        const username = 'Enesp4rl4k';
        const currentYear = new Date().getFullYear();

        // 1. GITHUB REPO & FOLLOWERS (adjusted to just REPO since followers is removed)
        fetch(`https://api.github.com/users/${username}`)
            .then(res => res.json())
            .then(data => {
                if(data.public_repos) document.getElementById('repo-count').innerText = data.public_repos;
            })
            .catch(err => console.log('GitHub API Error:', err));

        // 2. GITHUB CONTRIBUTIONS (Yıllık Katkı)
        fetch(`https://github-contributions-api.jogruber.de/v4/${username}`)
            .then(res => res.json())
            .then(data => {
                // Bulunduğumuz yılın verisini çekiyoruz
                const yearData = data.total[currentYear];
                if (yearData) {
                    document.getElementById('contrib-count').innerText = yearData;
                    // Başlığı da dinamik yapalım (Örn: Contributions 2025)
                    document.querySelector('#contrib-count + p').innerText = `Contributions (${currentYear})`;
                }
            })
            .catch(err => console.log('Contribution API Error:', err));

        // 3. TYPEWRITER EFFECT
        const textElement = document.getElementById('typewriter');
        const words = ["API Developer.", "Architect."];
        let wordIndex = 0, charIndex = 0, isDeleting = false;

        function type() {
            const currentWord = words[wordIndex];
            textElement.textContent = isDeleting ? currentWord.substring(0, charIndex - 1) : currentWord.substring(0, charIndex + 1);
            charIndex = isDeleting ? charIndex - 1 : charIndex + 1;
            let typeSpeed = isDeleting ? 100 : 200;
            if (!isDeleting && charIndex === currentWord.length) { isDeleting = true; typeSpeed = 2000; }
            else if (isDeleting && charIndex === 0) { isDeleting = false; wordIndex = (wordIndex + 1) % words.length; typeSpeed = 500; }
            setTimeout(type, typeSpeed);
        }
        type();

        // 4. SCROLL ANIMATIONS
        const sr = ScrollReveal({ origin: 'bottom', distance: '50px', duration: 1000, delay: 200 });
        sr.reveal('.hero-section, .section-title, .glass-card, .project-card, .contact-card-space', { interval: 150 });
        sr.reveal('.tech-icons i', { interval: 100, origin: 'bottom' });

        // --- EASTER EGGS ---

        // 5. CONSOLE MESSAGE
        console.log("%cAh, a fellow developer! \uD83D\uDC7E\nSince you're checking my code, you should check out my GitHub: https://github.com/Enesp4rl4k", "color: #00d4ff; font-size: 16px; font-weight: bold; padding: 10px; border: 2px solid #7000ff; border-radius: 5px;");

        // 6. KONAMI CODE (Matrix Mode)
        const konamiCode = ['ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'b', 'a'];
        let konamiIndex = 0;

        document.addEventListener('keydown', function(e) {
            if (e.key === konamiCode[konamiIndex]) {
                konamiIndex++;
                if (konamiIndex === konamiCode.length) {
                    activateMatrixMode();
                    konamiIndex = 0;
                }
            } else {
                konamiIndex = 0;
            }
        });

        function activateMatrixMode() {
            document.body.classList.add('matrix-mode');
            const canvas = document.getElementById('matrix-canvas');
            const ctx = canvas.getContext('2d');
            
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
            
            const katakana = 'アァカサタナハマヤャラワガザダバパイィキシチニヒミリヰギジヂビピウゥクスツヌフムユュルグズブヅプエェケセテネヘメレゲゼデベペオォコソトノホモヨョロゴゾドボポヴッン';
            const latin = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ';
            const nums = '0123456789';
            const chars = katakana + latin + nums;
            
            const fontSize = 16;
            const columns = canvas.width / fontSize;
            const drops = Array.from({length: columns}).fill(1);
            
            function drawMatrix() {
                ctx.fillStyle = 'rgba(0, 0, 0, 0.05)';
                ctx.fillRect(0, 0, canvas.width, canvas.height);
                ctx.fillStyle = '#0F0';
                ctx.font = fontSize + 'px monospace';
                
                for(let i = 0; i < drops.length; i++) {
                    const text = chars.charAt(Math.floor(Math.random() * chars.length));
                    ctx.fillText(text, i * fontSize, drops[i] * fontSize);
                    
                    if(drops[i] * fontSize > canvas.height && Math.random() > 0.977) {
                        drops[i] = 0;
                    }
                    drops[i]++;
                }
            }
            setInterval(drawMatrix, 33);
        }
    </script>
</body>
</html>