    <script src="https://unpkg.com/scrollreveal"></script>
    <script>
        const username = 'Enesp4rl4k';
        const currentYear = new Date().getFullYear();

        // 1. GITHUB REPO & FOLLOWER
        fetch(`https://api.github.com/users/${username}`)
            .then(res => res.json())
            .then(data => {
                if(data.public_repos) document.getElementById('repo-count').innerText = data.public_repos;
                if(data.followers) document.getElementById('follower-count').innerText = data.followers;
            })
            .catch(err => console.log('GitHub API Error:', err));

        // 2. GITHUB CONTRIBUTIONS (Yıllık Katkı)
        fetch(`https://github-contributions-api.jogruber.de/v4/${username}`)
            .then(res => res.json())
            .then(data => {
                // Bulunduğumuz yılın verisini çekiyoruz
                const yearData = data.total[currentYear];
                if (yearData) {
                    document.getElementById('contrib-count').innerText = yearData;
                    // Başlığı da dinamik yapalım (Örn: Contributions 2025)
                    document.querySelector('#contrib-count + p').innerText = `Contributions (${currentYear})`;
                }
            })
            .catch(err => console.log('Contribution API Error:', err));

        // 3. TYPEWRITER EFFECT
        const textElement = document.getElementById('typewriter');
        const words = ["Engineer.", "Architect.", "Developer."];
        let wordIndex = 0, charIndex = 0, isDeleting = false;

        function type() {
            const currentWord = words[wordIndex];
            textElement.textContent = isDeleting ? currentWord.substring(0, charIndex - 1) : currentWord.substring(0, charIndex + 1);
            charIndex = isDeleting ? charIndex - 1 : charIndex + 1;
            let typeSpeed = isDeleting ? 100 : 200;
            if (!isDeleting && charIndex === currentWord.length) { isDeleting = true; typeSpeed = 2000; }
            else if (isDeleting && charIndex === 0) { isDeleting = false; wordIndex = (wordIndex + 1) % words.length; typeSpeed = 500; }
            setTimeout(type, typeSpeed);
        }
        type();

        // 4. SCROLL ANIMATIONS
        const sr = ScrollReveal({ origin: 'bottom', distance: '50px', duration: 1000, delay: 200 });
        sr.reveal('.hero-section, .section-title, .glass-card, .project-card, .contact-card-space', { interval: 150 });
        sr.reveal('.tech-icons i', { interval: 100, origin: 'bottom' });
    </script>
