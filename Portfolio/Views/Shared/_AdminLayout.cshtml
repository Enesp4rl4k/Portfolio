<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { height: 100vh; background-color: #343a40; padding-top: 20px; }
        .sidebar a { color: #fff; text-decoration: none; padding: 10px 20px; display: block; }
        .sidebar a:hover { background-color: #495057; }
        .main-content { padding: 20px; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-2 d-none d-md-block sidebar">
                <div class="sidebar-sticky">
                    <h5 class="text-white text-center mb-4">Portfolio Admin</h5>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" href="/Feature/Index">
                                <i class="fas fa-heading me-2"></i> Hero Features
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/About/Index">
                                <i class="fas fa-user me-2"></i> About Me
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Experience/Index">
                                <i class="fas fa-briefcase me-2"></i> Experience Timeline
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Contact/Index">
                                <i class="fas fa-address-book me-2"></i> Contact Info
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Message/Index">
                                <i class="fas fa-inbox me-2"></i> Inbox (Messages)
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Skill/Index">
                                <i class="fas fa-code me-2"></i> Skills
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Portfolio/Index">
                                <i class="fas fa-briefcase me-2"></i> Projects
                            </a>
                        </li>
                        <li class="nav-item mt-5">
                            <a class="nav-link text-warning" href="/">
                                <i class="fas fa-globe me-2"></i> View Site
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>
            <main role="main" class="col-md-9 ms-sm-auto col-lg-10 px-4 main-content">
                @RenderBody()
            </main>
        </div>
    </div>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
