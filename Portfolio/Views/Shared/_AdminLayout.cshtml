<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Dashboard</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        :root {
            --bg-dark: #0f1015;
            --sidebar-bg: rgba(20, 21, 28, 0.7);
            --content-bg: rgba(255, 255, 255, 0.02);
            --border-glass: rgba(255, 255, 255, 0.08);
            --accent-purple: #7000ff;
            --accent-blue: #00d4ff;
            --text-main: #f8f9fa;
            --text-muted: #8b92a5;
            --hover-bg: rgba(112, 0, 255, 0.15);
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            overflow-x: hidden;
        }

        /* Abstract Background Glows */
        .bg-glow-1 {
            position: fixed;
            top: -100px;
            left: -100px;
            width: 400px;
            height: 400px;
            background: var(--accent-purple);
            filter: blur(150px);
            opacity: 0.15;
            z-index: -1;
            border-radius: 50%;
        }

        .bg-glow-2 {
            position: fixed;
            bottom: -100px;
            right: -100px;
            width: 500px;
            height: 500px;
            background: var(--accent-blue);
            filter: blur(150px);
            opacity: 0.1;
            z-index: -1;
            border-radius: 50%;
        }

        /* Modern Sidebar */
        .sidebar {
            height: 100vh;
            background: var(--sidebar-bg);
            backdrop-filter: blur(20px);
            border-right: 1px solid var(--border-glass);
            padding: 30px 15px;
            box-shadow: 5px 0 25px rgba(0,0,0,0.2);
        }

        .sidebar-brand {
            font-size: 1.4rem;
            font-weight: 800;
            color: #fff;
            text-align: center;
            margin-bottom: 40px;
            letter-spacing: 1px;
        }
        .sidebar-brand span { color: var(--accent-blue); }

        .sidebar .nav-item { margin-bottom: 5px; }

        .sidebar a {
            color: var(--text-muted);
            text-decoration: none;
            padding: 12px 20px;
            display: flex;
            align-items: center;
            border-radius: 12px;
            transition: all 0.3s ease;
            font-weight: 500;
            font-size: 0.95rem;
        }

        .sidebar a i {
            margin-right: 15px;
            font-size: 1.1rem;
            width: 20px;
            text-align: center;
            transition: 0.3s;
        }

        .sidebar a:hover, .sidebar a.active {
            background: var(--hover-bg);
            color: #fff;
            box-shadow: 0 0 15px rgba(112, 0, 255, 0.2);
        }

        .sidebar a:hover i, .sidebar a.active i {
            color: var(--accent-blue);
            transform: scale(1.1);
        }

        /* Main Content Area */
        .main-content {
            padding: 40px;
            min-height: 100vh;
        }

        /* Glassmorphic Cards inside content */
        .main-content .card, .main-content .table-responsive {
            background: var(--content-bg);
            backdrop-filter: blur(10px);
            border: 1px solid var(--border-glass);
            border-radius: 16px;
            padding: 25px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            margin-bottom: 30px;
            color: var(--text-main);
        }

        /* Customize scrollbar */
        ::-webkit-scrollbar { width: 8px; }
        ::-webkit-scrollbar-track { background: var(--bg-dark); }
        ::-webkit-scrollbar-thumb { background: var(--border-glass); border-radius: 10px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--accent-purple); }

    </style>
</head>
<body>
    <div class="bg-glow-1"></div>
    <div class="bg-glow-2"></div>

    <div class="container-fluid">
        <div class="row">
            <nav class="col-md-3 col-lg-2 d-none d-md-block sidebar">
                <div class="sidebar-sticky">
                    <div class="sidebar-brand">PORTFOLIO<span>.</span></div>
                    <ul class="nav flex-column">
                        <li class="nav-item">
                            <a class="nav-link" href="/Feature/Index">
                                <i class="fas fa-heading"></i> Hero Setting
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/About/Index">
                                <i class="fas fa-user-circle"></i> About Me
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Experience/Index">
                                <i class="fas fa-stream"></i> Experience
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Contact/Index">
                                <i class="fas fa-address-card"></i> Contact Info
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Message/Index">
                                <i class="fas fa-envelope-open-text"></i> Inbox
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Skill/Index">
                                <i class="fas fa-laptop-code"></i> Skills
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Portfolio/Index">
                                <i class="fas fa-project-diagram"></i> Projects
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/SocialMedia/Index">
                                <i class="fas fa-hashtag"></i> Social Media
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Testimonial/Index">
                                <i class="fas fa-comment-dots"></i> Testimonials
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Expertise/Index">
                                <i class="fas fa-microchip"></i> Expertise
                            </a>
                        </li>
                        <li class="nav-item mt-5 pt-3 border-top border-secondary">
                            <a class="nav-link" href="/" target="_blank" style="color: var(--accent-blue);">
                                <i class="fas fa-external-link-alt"></i> Live Site
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Login/Logout" style="color: #ff4d4d;">
                                <i class="fas fa-sign-out-alt"></i> Logout
                            </a>
                        </li>
                    </ul>
                </div>
            </nav>
            <main role="main" class="col-md-9 ms-sm-auto col-lg-10 px-4 main-content">
                @RenderBody()
            </main>
        </div>
    </div>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Simple active state logic for sidebar
        $(document).ready(function () {
            let currentPath = window.location.pathname;
            $('.sidebar .nav-link').each(function () {
                if ($(this).attr('href') === currentPath || (currentPath !== '/' && $(this).attr('href').startsWith(currentPath))) {
                    $(this).addClass('active');
                }
            });
        });
    </script>
</body>
</html>
