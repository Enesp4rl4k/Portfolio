@model List<MyPortfolio.DAL.Entities.Portfolio>

<section id="projects" class="py-5" data-aos="fade-up" data-aos-delay="400">
    <div class="row mb-5">
        <div class="col-12 text-center">
            <h2 class="fw-bold">My Projects</h2>
            <div class="heading-line mx-auto"></div>
        </div>
    </div>
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 mb-4">
                <div class="card h-100 shadow-sm border-0 project-card">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" class="card-img-top" alt="@item.Title" style="height: 200px; object-fit: cover;">
                    }
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title fw-bold">@item.Title</h5>
                        <h6 class="card-subtitle mb-2 text-muted">@item.Subtitle</h6>
                        <p class="card-text flex-grow-1">@item.Description</p>
                        <a href="@item.ProjectUrl" target="_blank" class="btn btn-outline-primary mt-auto rounded-pill w-100">
                            View on GitHub <i class="fas fa-arrow-right ms-1"></i>
                        </a>
                    </div>
                </div>
            </div>
        }
        
        <!-- Coming Soon Card -->
        <div class="col-lg-4 col-md-6 mb-4">
            <div class="card h-100 shadow-sm border-0 project-card d-flex justify-content-center align-items-center" style="border: 2px dashed rgba(255, 255, 255, 0.2) !important; background: rgba(255, 255, 255, 0.02) !important; min-height: 350px;">
                <div class="text-center p-4">
                    <i class="fas fa-laptop-code fa-3x mb-3" style="color: var(--accent-purple); opacity: 0.7;"></i>
                    <h5 class="card-title fw-bold text-white mb-2" style="opacity: 0.8;">Coming Soon</h5>
                    <p class="card-text text-muted">New architectural project currently in development.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .project-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
        background-color: var(--card-bg);
    }
    .project-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 20px rgba(0,0,0,0.2) !important;
    }
    .heading-line {
        width: 50px;
        height: 3px;
        background-color: #0d6efd;
        margin-top: 10px;
    }
</style>
