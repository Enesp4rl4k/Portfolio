@model MyPortfolio.DAL.Entities.SocialMedia

@{
    ViewData["Title"] = "Create Social Media";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card mt-4">
    <div class="card-header bg-success text-white">
        <h4 class="mb-0">Add New Social Media</h4>
    </div>
    <div class="card-body">
        <form method="post">
            <div class="mb-3">
                <label class="form-label">Platform Name</label>
                <input type="text" class="form-control" name="Title" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Icon (Font Awesome Class, e.g., fab fa-github)</label>
                <input type="text" class="form-control" name="Icon" required />
            </div>
            <div class="mb-3">
                <label class="form-label">URL</label>
                <input type="url" class="form-control" name="Url" required />
            </div>
            <button class="btn btn-success" type="submit">Create Account</button>
            <a href="/SocialMedia/Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
