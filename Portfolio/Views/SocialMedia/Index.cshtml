@model List<MyPortfolio.DAL.Entities.SocialMedia>

@{
    ViewData["Title"] = "Social Media List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card mt-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">Social Media Accounts</h4>
        <a href="/SocialMedia/Create" class="btn btn-sm btn-success">Add New Account</a>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Platform</th>
                    <th>Icon</th>
                    <th>URL</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.SocialMediaId</td>
                        <td>@item.Title</td>
                        <td><i class="@item.Icon"></i> (@item.Icon)</td>
                        <td><a href="@item.Url" target="_blank">@item.Url</a></td>
                        <td>
                            <a href="/SocialMedia/Edit/@item.SocialMediaId" class="btn btn-sm btn-primary">Edit</a>
                            <a href="/SocialMedia/Delete/@item.SocialMediaId" class="btn btn-sm btn-danger" onclick="return confirm('Delete this account?');">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
