@model MyPortfolio.DAL.Entities.About

@{
    ViewData["Title"] = "Edit About";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card mt-4">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">Edit About Entry</h4>
    </div>
    <div class="card-body">
        <form method="post">
            <input type="hidden" name="AboutId" value="@Model.AboutId" />
            <div class="mb-3">
                <label class="form-label">Title</label>
                <input type="text" class="form-control" name="Title" value="@Model.Title" required />
            </div>
            <div class="mb-3">
                <label class="form-label">SubDescription</label>
                <input type="text" class="form-control" name="SubDescription" value="@Model.SubDescription" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Details</label>
                <textarea class="form-control" name="Details" rows="5" required>@Model.Details</textarea>
            </div>
            <button class="btn btn-primary" type="submit">Update About</button>
            <a href="/About/Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>
