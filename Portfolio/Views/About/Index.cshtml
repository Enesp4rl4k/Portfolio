@model List<MyPortfolio.DAL.Entities.About>

@{
    ViewData["Title"] = "About List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="card mt-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h4 class="mb-0">About Me Entries</h4>
        <a href="/About/Create" class="btn btn-sm btn-success">Add New Entry</a>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Title</th>
                    <th>SubDescription</th>
                    <th>Details</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.AboutId</td>
                        <td>@item.Title</td>
                        <td>@item.SubDescription</td>
                        <td>@(item.Details.Length > 50 ? item.Details.Substring(0, 50) + "..." : item.Details)</td>
                        <td>
                            <a href="/About/Edit/@item.AboutId" class="btn btn-sm btn-primary">Edit</a>
                            <a href="/About/Delete/@item.AboutId" class="btn btn-sm btn-danger" onclick="return confirm('Delete this entry?');">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
